# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1
LLM_MODEL=gpt-4o-mini

# Database (SQLite path)
DATABASE_URL=sqlite+aiosqlite:///./data/manolo.sqlite3

# FX (default: open.er-api.com latest USD rates)
FX_API_URL=https://open.er-api.com/v6/latest/USD

# Orchestrator
MAX_STEPS=10
MAX_TOOL_CALLS=10
ALLOWED_TOOLS=calendar_tool,usd_price_tool

# Server
HOST=127.0.0.1
PORT=8000
